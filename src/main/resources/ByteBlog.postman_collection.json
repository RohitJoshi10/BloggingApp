        {
          "name": "Get All Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "",
                  "var template = `",
                  "<canvas id=\"commentsChart\" height=\"100\"></canvas>",
                  "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.5.0/Chart.min.js\"></script>",
                  "<script>",
                  "    var ctx = document.getElementById(\"commentsChart\");",
                  "    var myChart = new Chart(ctx, {",
                  "        type: \"bar\",",
                  "        data: {",
                  "            labels: [],",
                  "            datasets: [{",
                  "                label: \"Number of Comments\",",
                  "                data: [],",
                  "                backgroundColor: \"rgba(54, 162, 235, 0.6)\",",
                  "                borderColor: \"rgba(54, 162, 235, 1)\",",
                  "                borderWidth: 1",
                  "            }]",
                  "        },",
                  "        options: {",
                  "            legend: { display: true },",
                  "            title: {",
                  "                display: true,",
                  "                text: \"Comments per Blog Post\"",
                  "            },",
                  "            scales: {",
                  "                xAxes: [{",
                  "                    display: true,",
                  "                    scaleLabel: {",
                  "                        display: true,",
                  "                        labelString: \"Post Title\"",
                  "                    },",
                  "                    ticks: {",
                  "                        autoSkip: false",
                  "                    }",
                  "                }],",
                  "                yAxes: [{",
                  "                    display: true,",
                  "                    scaleLabel: {",
                  "                        display: true,",
                  "                        labelString: \"Comment Count\"",
                  "                    },",
                  "                    ticks: {",
                  "                        beginAtZero: true,",
                  "                        stepSize: 1",
                  "                    }",
                  "                }]",
                  "            }",
                  "        }",
                  "    });",
                  "",
                  "    pm.getData(function (err, value) {",
                  "        myChart.data.labels = value.posts.map(function(post) { return post.title; });",
                  "        myChart.data.datasets[0].data = value.posts.map(function(post) { return post.commentCount; });",
                  "        myChart.update();",
                  "    });",
                  "</script>",
                  "`;",
                  "",
                  "function constructVisualizerPayload() {",
                  "    var jsonData = pm.response.json();",
                  "    var posts = jsonData.content.map(function(post) {",
                  "        return {",
                  "            title: post.title,",
                  "            commentCount: post.comments ? post.comments.length : 0",
                  "        };",
                  "    });",
                  "    return { posts: posts };",
                  "}",
                  "",
                  "pm.visualizer.set(template, constructVisualizerPayload());",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
